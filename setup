#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "${SCRIPT_DIR}/variants.conf"

declare -A DIR_CONTEXT
DIR_CONTEXT[apps]="Applications"
DIR_CONTEXT[devices]="Devices"
DIR_CONTEXT[mimetypes]="MimeTypes"
DIR_CONTEXT[places]="Places"
DIR_CONTEXT[status]="Status"
DIR_CONTEXT[actions]="Actions"
DIR_CONTEXT[categories]="Categories"
DIR_CONTEXT[emblems]="Emblems"
DIR_CONTEXT[emotes]="Emotes"
DIR_CONTEXT[legacy]="Legacy"
DIR_CONTEXT[ui]="UI"

# --- Help ---
show_help() {
    cat << EOF
Usage: $(basename "$0") [OPTIONS] [variant1 variant2 ...]

Install or remove Adwaita Colors icon theme variants.

Options:
    -i, --install           Generate and install icon themes
    -u, --uninstall         Remove icon themes from system
    -f, --folders           Include custom folder icons (GitHub, GitLab, etc.)
    -P, --prefix=PATH       Install prefix (e.g. /usr, ~/.local)
    -l, --list              List available variants
    -h, --help              Show this help message

Variants:
    If no variants are specified, all variants are processed.

Examples:
    $(basename "$0") -i                  Generate and install all
    $(basename "$0") -if                 Generate and install with custom folders
    $(basename "$0") -i -f teal          Just teal with custom folders
    $(basename "$0") -u                  Uninstall all from system
    $(basename "$0") -u -P /usr          Uninstall from /usr/share/icons
    $(basename "$0") -i -P /app          Install to /app/share/icons
EOF
}

# --- Locate system Adwaita ---
find_adwaita() {
    for p in "${ADWAITA_PATHS[@]}"; do
        expanded=$(eval echo "$p")
        if [ -d "$expanded/scalable" ]; then
            echo "$expanded"
            return 0
        fi
    done
    echo ""
    return 1
}

# --- Generate index.theme ---
generate_index() {
    local variant="$1"
    local theme_dir="$2"

    local inherits="Adwaita,AdwaitaLegacy,hicolor"
    if [ "$variant" != "blue" ]; then
        inherits="Adwaita,Adwaita-blue,AdwaitaLegacy,hicolor"
    fi

    local dirs=""
    if [ -d "$theme_dir/scalable" ]; then
        for d in "$theme_dir/scalable"/*/; do
            dname=$(basename "$d")
            [ -z "$dirs" ] && dirs="scalable/${dname}" || dirs="${dirs},scalable/${dname}"
        done
    fi

    cat > "${theme_dir}/index.theme" << THEMEOF
[Icon Theme]
Name=Adwaita-${variant}
Comment=The Only One
Example=folder
Inherits=${inherits}
Hidden=true

# KDE Specific Stuff
DisplayDepth=32
DesktopDefault=48
DesktopSizes=16,22,32,48,64,72,96,128
ToolbarDefault=22
ToolbarSizes=16,22,32,48
MainToolbarDefault=22
MainToolbarSizes=16,22,32,48
SmallDefault=16
SmallSizes=16
PanelDefault=32
PanelSizes=16,22,32,48,64,72,96,128

# Directory list
Directories=${dirs},
THEMEOF

    for d in "$theme_dir/scalable"/*/; do
        dname=$(basename "$d")
        context="${DIR_CONTEXT[$dname]:-Applications}"
        cat >> "${theme_dir}/index.theme" << DIRSEC

[scalable/${dname}]
Context=${context}
Size=128
MinSize=8
MaxSize=512
Type=Scalable
DIRSEC
    done
}

# --- Color replacement ---
recolor_svgs() {
    local variant="$1"
    local theme_dir="$2"
    local mapping="${COLOR_MAP[$variant]:-}"
    [ -z "$mapping" ] && return 0

    local sed_expr=""
    for pair in $mapping; do
        src="${pair%%:*}"
        dst="${pair##*:}"
        [ -n "$sed_expr" ] && sed_expr+="; "
        sed_expr+="s/#${src}/#${dst}/Ig"
    done

    find "$theme_dir" -name '*.svg' -exec sed -i "$sed_expr" {} +
}

# --- Remove SVGs unchanged from system Adwaita (they inherit) ---
dedup_svgs() {
    local theme_dir="$1"
    local adwaita_src="$2"

    for svg in "$theme_dir/scalable"/*/*.svg; do
        [ -f "$svg" ] || continue
        local rel="${svg#$theme_dir/scalable/}"
        local sys_svg="${adwaita_src}/scalable/${rel}"
        if [ -f "$sys_svg" ] && cmp -s "$svg" "$sys_svg"; then
            rm "$svg"
            continue
        fi
        # Remove files in the skip list (accent blues in non-accent contexts)
        for skip in "${SKIP_FILES[@]}"; do
            if [ "$rel" = "$skip" ]; then
                rm "$svg"
                break
            fi
        done
    done
    # Remove empty directories left behind
    for d in "$theme_dir/scalable"/*/; do
        [ -d "$d" ] && rmdir "$d" 2>/dev/null || true
    done
}

# --- Create mimetype symlinks ---
create_mimetype_symlinks() {
    local mimetype_dir="$1"
    for entry in "${MIMETYPE_SYMLINKS[@]}"; do
        local link="${entry%%:*}"
        local target="${entry##*:}"
        if [ ! -e "$mimetype_dir/$link" ]; then
            ln -s "$target" "$mimetype_dir/$link" 2>/dev/null || true
        fi
    done
}

# --- Generate one variant ---
generate_variant() {
    local variant="$1"
    local output_dir="$2"
    local adwaita_src="$3"
    local with_folders="${4:-false}"
    local theme_dir="${output_dir}/Adwaita-${variant}"

    echo "  Generating Adwaita-${variant}..."
    rm -rf "$theme_dir"
    mkdir -p "$theme_dir/scalable"

    # 1. Copy accent-colored SVGs from system Adwaita (places, status)
    for dir in $ADWAITA_DIRS; do
        local src_dir="${adwaita_src}/scalable/${dir}"
        if [ -d "$src_dir" ]; then
            cp -r "$src_dir" "${theme_dir}/scalable/${dir}"
        else
            echo "    Warning: ${src_dir} not found, skipping"
        fi
    done

    # 2. Copy apps/ (per-variant pre-colored, no recolor)
    local apps_src="${SCRIPT_DIR}/apps/${variant}"
    if [ -d "$apps_src" ]; then
        mkdir -p "${theme_dir}/scalable/apps"
        cp -a "$apps_src"/*.svg "${theme_dir}/scalable/apps/" 2>/dev/null || true
    fi

    # 3. Recolor everything so far
    recolor_svgs "$variant" "$theme_dir"
    dedup_svgs "$theme_dir" "$adwaita_src"

    # 4. Custom folder SVGs (if requested, from single blue source)
    if [ "$with_folders" = true ]; then
        mkdir -p "${theme_dir}/scalable/places"
        for f in "${SCRIPT_DIR}/folders/"*.svg; do
            [ -f "$f" ] && cp -a "$f" "${theme_dir}/scalable/places/"
        done
        for l in "${SCRIPT_DIR}/folders/"*; do
            [ -L "$l" ] && cp -a "$l" "${theme_dir}/scalable/places/"
        done
        recolor_svgs "$variant" "$theme_dir"
    fi

    # 5. Fixed per-variant mimetypes (pre-colored, recolor fixes any leftover blues)
    local mime_src="${SCRIPT_DIR}/mimetypes/${variant}"
    if [ -d "$mime_src" ]; then
        mkdir -p "${theme_dir}/scalable/mimetypes"
        for f in "$mime_src"/*.svg; do
            [ -f "$f" ] && cp "$f" "${theme_dir}/scalable/mimetypes/"
        done
        recolor_svgs "$variant" "$theme_dir"
        create_mimetype_symlinks "${theme_dir}/scalable/mimetypes"
    fi

    generate_index "$variant" "$theme_dir"

    if command -v gtk-update-icon-cache &> /dev/null; then
        gtk-update-icon-cache -f "$theme_dir" &> /dev/null || true
    fi
}

# --- Install helpers ---
need_sudo() {
    local path="$1"
    # Walk up until we find an existing directory
    while [[ ! -d "$path" && "$path" != "/" ]]; do
        path="$(dirname "$path")"
    done
    if [[ -w "$path" ]]; then
        return 1
    else
        return 0
    fi
}

get_install_path() {
    local prefix="$1"
    local mode="$2"

    if [[ -z "$prefix" ]]; then
        if [[ "$mode" == "install" ]]; then
            if [[ $EUID -eq 0 ]] || [[ -w "/usr/share" ]]; then
                echo "/usr/share/icons"
            else
                echo "$HOME/.local/share/icons"
            fi
        else
            for p in "/usr/share/icons" "/usr/local/share/icons" "/var/usr/local/share/icons" "$HOME/.local/share/icons" "$HOME/.icons"; do
                if [[ -d "$p" ]] && [[ -n "$(find "$p" -maxdepth 1 -type d -name 'Adwaita-*' -print -quit 2>/dev/null)" ]]; then
                    echo "$p"
                    return
                fi
            done
            echo "/usr/share/icons"
        fi
        return
    fi

    prefix="${prefix/#\~/$HOME}"
    if [[ "$prefix" == "/" ]]; then
        echo "/usr/share/icons"
    else
        echo "${prefix}/share/icons"
    fi
}

update_icon_cache() {
    local path="$1"
    echo "  Updating icon cache..."

    if need_sudo "$path"; then
        if command -v gtk-update-icon-cache &> /dev/null; then
            sudo gtk-update-icon-cache -f "$path" 2>/dev/null || true
        elif command -v xdg-icon-resource &> /dev/null; then
            sudo xdg-icon-resource forceupdate 2>/dev/null || true
        fi
    else
        if command -v gtk-update-icon-cache &> /dev/null; then
            gtk-update-icon-cache -f "$path" 2>/dev/null || true
        elif command -v xdg-icon-resource &> /dev/null; then
            xdg-icon-resource forceupdate 2>/dev/null || true
        fi
    fi
}

# --- Install ---
do_install() {
    local with_folders="$1"
    local prefix="$2"
    shift 2
    local variants=("$@")

    local install_path
    install_path=$(get_install_path "$prefix" "install")

    # Find system Adwaita
    local adwaita_src
    adwaita_src=$(find_adwaita) || true
    if [ -z "$adwaita_src" ]; then
        echo "Error: System Adwaita icon theme not found."
        echo "Install the 'adwaita-icon-theme' package and try again."
        exit 1
    fi

    echo "Generating ${#variants[@]} variant(s) from ${adwaita_src}..."
    mkdir -p "$SCRIPT_DIR"
    for variant in "${variants[@]}"; do
        generate_variant "$variant" "$SCRIPT_DIR" "$adwaita_src" "$with_folders"
    done

    echo ""
    echo "Installing to ${install_path}..."

    if need_sudo "$install_path"; then
        sudo mkdir -p "$install_path"
        for variant in "${variants[@]}"; do
            local src="${SCRIPT_DIR}/Adwaita-${variant}"
            echo "  Installing Adwaita-${variant}..."
            sudo cp -r "$src" "$install_path/"
        done
    else
        mkdir -p "$install_path"
        for variant in "${variants[@]}"; do
            local src="${SCRIPT_DIR}/Adwaita-${variant}"
            echo "  Installing Adwaita-${variant}..."
            cp -r "$src" "$install_path/"
        done
    fi

    # Clean up local generated copies
    rm -rf "${SCRIPT_DIR}"/Adwaita-*

    update_icon_cache "$install_path"
    echo "Installation complete."
}

# --- Uninstall ---
do_uninstall() {
    local prefix="$1"
    local install_path
    install_path=$(get_install_path "$prefix" "uninstall")

    echo "Removing from ${install_path}..."

    if [[ ! -d "$install_path" ]]; then
        echo "Warning: Directory does not exist: $install_path"
        return 0
    fi

    local dirs=()
    if need_sudo "$install_path"; then
        while IFS= read -r -d '' dir; do
            dirs+=("$dir")
        done < <(sudo find "$install_path" -maxdepth 1 -type d -name "Adwaita-*" -print0 2>/dev/null)
    else
        while IFS= read -r -d '' dir; do
            dirs+=("$dir")
        done < <(find "$install_path" -maxdepth 1 -type d -name "Adwaita-*" -print0 2>/dev/null)
    fi

    if [[ ${#dirs[@]} -eq 0 ]]; then
        echo "  No Adwaita-* directories found."
        update_icon_cache "$install_path"
        return 0
    fi

    echo "  Found:"
    for dir in "${dirs[@]}"; do
        echo "    $(basename "$dir")"
    done

    if [[ ! -t 0 ]]; then
        # Non-interactive: skip confirmation (used by -u flag)
        local confirm="y"
    else
        read -p "  Remove these? (y/N): " -n 1 -r confirm
        echo
        _flush_stdin
    fi
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo "  Cancelled."
        return 0
    fi

    for dir in "${dirs[@]}"; do
        if need_sudo "$install_path"; then
            sudo rm -rf "$dir"
        else
            rm -rf "$dir"
        fi
    done

    update_icon_cache "$install_path"
    echo "Uninstall complete."
}

# --- Interactive questionnaire ---
_flush_stdin() {
    # Drain any leftover input after a single-character read
    # Use a named variable to avoid overwriting REPLY
    local _ignore
    read -r -t 0.1 -d '' -n 10000 _ignore 2>/dev/null || true
}

_prompt_choice() {
    local prompt="$1" default="$2"
    local reply
    read -p "$prompt" reply
    echo "${reply:-$default}"
}

_prompt_confirm() {
    local reply
    read -p "  Proceed? (Y/n): " -n 1 reply
    echo ""
    _flush_stdin
    [[ -z "$reply" || "$reply" =~ ^[Yy]$ ]]
}

run_interactive() {
    local mode="" variants=() prefix=""

    echo ""
    echo "  Adwaita Colors — Setup"
    echo "  ======================"
    echo ""

    # Step 1: action
    echo "  What would you like to do?"
    echo "    1) Install icon themes"
    echo "    2) Remove icon themes"
    local action_choice
    action_choice=$(_prompt_choice "  (1/2): " "1")
    case "$action_choice" in
        1) mode="install" ;;
        2) mode="uninstall" ;;
        *) echo "  Invalid choice."; exit 1 ;;
    esac

    # Step 2: variants
    echo ""
    echo "  Which color variants?"
    echo "    1) All 10 variants"
    echo "    2) Choose specific variants"
    local var_choice
    var_choice=$(_prompt_choice "  (1/2): " "1")

    if [[ "$var_choice" == "2" ]]; then
        echo ""
        echo "  Enter numbers separated by commas or spaces"
        for i in "${!ALL_VARIANTS[@]}"; do
            printf "    %2d) %s\n" $((i + 1)) "${ALL_VARIANTS[$i]}"
        done
        local selection raw_tokens
        read -p "  Selection: " selection
        # Split on both commas and spaces
        IFS=',' read -ra raw_tokens <<< "$selection"
        for part in "${raw_tokens[@]}"; do
            for token in $part; do
                if [[ "$token" =~ ^[0-9]+$ ]]; then
                    local idx=$((token - 1))
                    if [[ $idx -ge 0 && $idx -lt ${#ALL_VARIANTS[@]} ]]; then
                        variants+=("${ALL_VARIANTS[$idx]}")
                    fi
                fi
            done
        done
        if [[ ${#variants[@]} -eq 0 ]]; then
            echo "  No valid variants selected, using all."
            variants=("${ALL_VARIANTS[@]}")
        fi
    else
        variants=("${ALL_VARIANTS[@]}")
    fi

    # Step 3: location (install only)
    local with_folders=false
    if [[ "$mode" == "install" ]]; then
        echo ""
        echo "  Install location?"
        echo "    1) System-wide (/usr/share/icons) — may need sudo"
        echo "    2) Just for my user (~/.local/share/icons)"
        echo "    3) Custom path"
        local loc_choice
        loc_choice=$(_prompt_choice "  (1/2/3): " "2")

        case "$loc_choice" in
            1) PREFIX="" ;;  # auto-detect system
            2) PREFIX="$HOME/.local" ;;
            3) read -p "  Enter path (e.g. /usr, /app, ~/.local): " PREFIX ;;
            *) echo "  Invalid choice."; exit 1 ;;
        esac

        # Step 4: custom folders
        echo ""
        echo "  Include additional custom folder icons? (y/N)"
        echo "    These add branded folder icons (GitHub, GitLab, etc.)"
        local folder_choice
        read -p "  (y/N): " -n 1 folder_choice
        echo ""
        _flush_stdin
        [[ "$folder_choice" =~ ^[Yy]$ ]] && with_folders=true
    fi

    # Summary
    echo ""
    echo "  Summary"
    echo "  -------"
    echo "  Action:   ${mode}"
    echo "  Variants: ${variants[*]}"
    if [[ "$mode" == "install" ]]; then
        local path
        path=$(get_install_path "$PREFIX" "install")
        echo "  Location: ${path}"
        if need_sudo "$path"; then
            echo "  (sudo will be used)"
        fi
        echo "  Custom folders: $([ "$with_folders" = true ] && echo yes || echo no)"
    fi
    _prompt_confirm || { echo "  Cancelled."; exit 0; }

    # Execute
    case "$mode" in
        install)   do_install "$with_folders" "$PREFIX" "${variants[@]}" ;;
        uninstall) do_uninstall "$PREFIX" ;;
    esac
}

# --- Main ---

PREFIX=""
MODE=""
WITH_FOLDERS=false
VARIANTS=()

# No args at all → interactive mode
if [[ $# -eq 0 ]]; then
    run_interactive
    exit 0
fi

while [[ $# -gt 0 ]]; do
    case $1 in
        -i|--install)     MODE="install"; shift ;;
        -u|--uninstall)   MODE="uninstall"; shift ;;
        -f|--folders)     WITH_FOLDERS=true; shift ;;
        -P|--prefix)      PREFIX="$2"; shift 2 ;;
        -P=*|--prefix=*)  PREFIX="${1#*=}"; shift ;;
        -l|--list)        echo "Available variants: ${ALL_VARIANTS[*]}"; exit 0 ;;
        -h|--help)        show_help; exit 0 ;;
        -*)
            echo "Unknown option: $1"
            echo "Use -h or --help for usage information."
            exit 1
            ;;
        *)
            VARIANTS+=("$1")
            shift
            ;;
    esac
done

if [ -z "$MODE" ]; then
    echo "Error: Specify -i (install) or -u (uninstall)."
    echo "Use -h or --help for usage information."
    exit 1
fi

if [ ${#VARIANTS[@]} -eq 0 ]; then
    VARIANTS=("${ALL_VARIANTS[@]}")
fi

for v in "${VARIANTS[@]}"; do
    valid=false
    for av in "${ALL_VARIANTS[@]}"; do
        [ "$v" = "$av" ] && { valid=true; break; }
    done
    if [ "$valid" = false ]; then
        echo "Error: Unknown variant '$v'"
        echo "Available variants: ${ALL_VARIANTS[*]}"
        exit 1
    fi
done

case "$MODE" in
    install)   do_install "$WITH_FOLDERS" "$PREFIX" "${VARIANTS[@]}" ;;
    uninstall) do_uninstall "$PREFIX" ;;
esac

exit 0
