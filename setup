#!/bin/bash

set -eo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/variants.conf"

declare -A DIR_CONTEXT
DIR_CONTEXT[apps]="Applications"
DIR_CONTEXT[mimetypes]="MimeTypes"
DIR_CONTEXT[places]="Places"
DIR_CONTEXT[status]="Status"
DIR_CONTEXT[actions]="Actions"
DIR_CONTEXT[categories]="Categories"
DIR_CONTEXT[emblems]="Emblems"
DIR_CONTEXT[emotes]="Emotes"
DIR_CONTEXT[legacy]="Legacy"
DIR_CONTEXT[ui]="UI"

# Build a lookup for valid variants (used for validation)
declare -A IS_VALID_VARIANT
for v in "${ALL_VARIANTS[@]}"; do
    IS_VALID_VARIANT[$v]=1
done

# --- Help ---
show_help() {
    cat << EOF
Usage: $(basename "$0") [OPTIONS] [variant1 variant2 ...]

Install or remove Adwaita Colors icon theme variants.

Options:
    -i, --install           Generate and install icon themes
    -u, --uninstall         Remove icon themes from system
    -f, --folders           Include custom folder icons (GitHub, GitLab, etc.)
    -P, --prefix=PATH       Install prefix (e.g. /usr, ~/.local)
    -l, --list              List available variants
    -h, --help              Show this help message

Variants:
    If no variants are specified, all variants are processed.

Examples:
    $(basename "$0") -i                  Generate and install all
    $(basename "$0") -if                 Generate and install with custom folders
    $(basename "$0") -i -f teal          Just teal with custom folders
    $(basename "$0") -u                  Uninstall all from system
    $(basename "$0") -u -P /usr          Uninstall from /usr/share/icons
    $(basename "$0") -i -P /app          Install to /app/share/icons
EOF
}

# --- Helpers ---

# Run a command with sudo if the target path requires it
_run_as() {
    local path="$1"; shift
    # Walk up to find an existing directory for writability check
    local check="$path"
    while [[ ! -d "$check" && "$check" != "/" ]]; do
        check="$(dirname "$check")"
    done
    if [[ -w "$check" ]]; then
        "$@"
    else
        sudo "$@"
    fi
}

find_adwaita() {
    for p in "${ADWAITA_PATHS[@]}"; do
        if [ -d "$p/scalable" ]; then
            echo "$p"
            return 0
        fi
    done
    echo ""
    return 1
}

get_install_path() {
    local prefix="$1" mode="$2"
    if [[ -z "$prefix" ]]; then
        if [[ "$mode" == "install" ]]; then
            if [[ $EUID -eq 0 ]] || [[ -w "/usr/share" ]]; then
                echo "/usr/share/icons"
            else
                echo "$HOME/.local/share/icons"
            fi
        else
            for p in "${ADWAITA_PATHS[@]}"; do
                local base="${p%/Adwaita}"
                if [[ -d "$base" ]] && [[ -n "$(find "$base" -maxdepth 1 -type d -name 'Adwaita-*' -print -quit 2>/dev/null)" ]]; then
                    echo "$base"
                    return
                fi
            done
            echo "/usr/share/icons"
        fi
        return
    fi
    prefix="${prefix/#\~/$HOME}"
    [[ "$prefix" == "/" ]] && echo "/usr/share/icons" || echo "${prefix}/share/icons"
}

# --- Generate index.theme ---
generate_index() {
    local variant="$1" theme_dir="$2"
    local inherits="Adwaita,AdwaitaLegacy,hicolor"
    [[ "$variant" != "blue" ]] && inherits="Adwaita,Adwaita-blue,AdwaitaLegacy,hicolor"

    local dirs=()
    for d in "$theme_dir/scalable"/*/; do
        dirs+=("scalable/$(basename "$d")")
    done

    cat > "${theme_dir}/index.theme" << THEMEOF
[Icon Theme]
Name=Adwaita-${variant}
Comment=The Only One
Example=folder
Inherits=${inherits}
Hidden=true

# KDE Specific Stuff
DisplayDepth=32
DesktopDefault=48
DesktopSizes=16,22,32,48,64,72,96,128
ToolbarDefault=22
ToolbarSizes=16,22,32,48
MainToolbarDefault=22
MainToolbarSizes=16,22,32,48
SmallDefault=16
SmallSizes=16
PanelDefault=32
PanelSizes=16,22,32,48,64,72,96,128

# Directory list
Directories=$(IFS=,; echo "${dirs[*]}"),
THEMEOF

    for d in "$theme_dir/scalable"/*/; do
        local dname=$(basename "$d")
        cat >> "${theme_dir}/index.theme" << DIRSEC

[scalable/${dname}]
Context=${DIR_CONTEXT[$dname]:-Applications}
Size=128
MinSize=8
MaxSize=512
Type=Scalable
DIRSEC
    done
}

# --- Color replacement ---
recolor_svgs() {
    local variant="$1" theme_dir="$2"
    local mapping="${COLOR_MAP[$variant]:-}"
    [[ -z "$mapping" ]] && return 0

    local sed_args=()
    for pair in $mapping; do
        sed_args+=(-e "s/#${pair%%:*}/#${pair##*:}/Ig")
    done

    find "$theme_dir" -name '*.svg' -exec sed -i "${sed_args[@]}" {} +
}

# --- Remove SVGs unchanged from system Adwaita (they inherit) ---
dedup_svgs() {
    local theme_dir="$1" adwaita_src="$2"

    for svg in "$theme_dir/scalable"/*/*.svg; do
        [[ -f "$svg" ]] || continue
        local rel="${svg#$theme_dir/scalable/}"
        local sys_svg="${adwaita_src}/scalable/${rel}"

        # Skip if unchanged from system (inherits) or in skip list
        if [ -f "$sys_svg" ] && cmp -s "$svg" "$sys_svg"; then
            rm "$svg"
        else
            for skip in "${SKIP_FILES[@]}"; do
                [ "$rel" = "$skip" ] && { rm "$svg"; break; }
            done
        fi
    done
    for d in "$theme_dir/scalable"/*/; do
        rmdir "$d" 2>/dev/null || true
    done
}

# --- Create mimetype symlinks ---
create_mimetype_symlinks() {
    local mimetype_dir="$1"
    for entry in "${MIMETYPE_SYMLINKS[@]}"; do
        local link="${entry%%:*}" target="${entry##*:}"
        [[ ! -e "$mimetype_dir/$link" ]] && ln -s "$target" "$mimetype_dir/$link" 2>/dev/null || true
    done
}

# --- Generate one variant ---
generate_variant() {
    local variant="$1" output_dir="$2" adwaita_src="$3" with_folders="${4:-false}"
    local theme_dir="${output_dir}/Adwaita-${variant}"

    echo "  Generating Adwaita-${variant}..."
    rm -rf "$theme_dir"
    mkdir -p "$theme_dir/scalable"

    for dir in $ADWAITA_DIRS; do
        local src_dir="${adwaita_src}/scalable/${dir}"
        if [ -d "$src_dir" ]; then
            cp -r "$src_dir" "${theme_dir}/scalable/${dir}"
        else
            echo "    Warning: ${src_dir} not found, skipping"
        fi
    done

    # Apps (per-variant pre-colored)
    local apps_src="${SCRIPT_DIR}/apps/${variant}"
    if [ -d "$apps_src" ]; then
        mkdir -p "${theme_dir}/scalable/apps"
        cp -a "$apps_src"/*.svg "${theme_dir}/scalable/apps/" 2>/dev/null || true
    fi

    # Recolor + dedup
    recolor_svgs "$variant" "$theme_dir"
    dedup_svgs "$theme_dir" "$adwaita_src"

    # Custom folders
    if [ "$with_folders" = true ]; then
        mkdir -p "${theme_dir}/scalable/places"
        cp -a "${SCRIPT_DIR}/folders/"* "${theme_dir}/scalable/places/"
        recolor_svgs "$variant" "$theme_dir"
    fi

    # Fixed per-variant mimetypes
    local mime_src="${SCRIPT_DIR}/mimetypes/${variant}"
    if [ -d "$mime_src" ]; then
        mkdir -p "${theme_dir}/scalable/mimetypes"
        cp -a "$mime_src"/*.svg "${theme_dir}/scalable/mimetypes/" 2>/dev/null || true
        recolor_svgs "$variant" "$theme_dir"
        create_mimetype_symlinks "${theme_dir}/scalable/mimetypes"
    fi

    generate_index "$variant" "$theme_dir"
}

update_icon_cache() {
    echo "  Updating icon cache..."
    if command -v gtk-update-icon-cache &> /dev/null; then
        _run_as "$1" gtk-update-icon-cache -f "$1" 2>/dev/null || true
    fi
}

# --- Install ---
do_install() {
    local with_folders="$1" prefix="$2"
    shift 2
    local variants=("$@")

    local install_path
    install_path=$(get_install_path "$prefix" "install")

    local adwaita_src
    adwaita_src=$(find_adwaita) || true
    if [ -z "$adwaita_src" ]; then
        echo "Error: System Adwaita icon theme not found."
        echo "Install the 'adwaita-icon-theme' package and try again."
        exit 1
    fi

    echo "Generating ${#variants[@]} variant(s) from ${adwaita_src}..."
    for variant in "${variants[@]}"; do
        generate_variant "$variant" "$SCRIPT_DIR" "$adwaita_src" "$with_folders"
    done

    echo ""
    echo "Installing to ${install_path}..."
    _run_as "$install_path" mkdir -p "$install_path"
    for variant in "${variants[@]}"; do
        local src="${SCRIPT_DIR}/Adwaita-${variant}"
        echo "  Installing Adwaita-${variant}..."
        _run_as "$install_path" cp -r "$src" "$install_path/"
    done

    rm -rf "${SCRIPT_DIR}"/Adwaita-*
    update_icon_cache "$install_path"
    echo "Installation complete."
}

# --- Uninstall ---
do_uninstall() {
    local install_path
    install_path=$(get_install_path "$1" "uninstall")

    echo "Removing from ${install_path}..."
    [[ ! -d "$install_path" ]] && { echo "Warning: Directory does not exist: $install_path"; return 0; }

    local dirs=()
    while IFS= read -r -d '' dir; do
        dirs+=("$dir")
    done < <(_run_as "$install_path" find "$install_path" -maxdepth 1 -type d -name "Adwaita-*" -print0 2>/dev/null)

    if [[ ${#dirs[@]} -eq 0 ]]; then
        echo "  No Adwaita-* directories found."
        update_icon_cache "$install_path"
        return 0
    fi

    echo "  Found:"
    for dir in "${dirs[@]}"; do
        echo "    $(basename "$dir")"
    done

    if [[ -t 0 ]]; then
        local confirm
        read -p "  Remove these? (y/N): " confirm
        [[ ! "$confirm" =~ ^[Yy]$ ]] && { echo "  Cancelled."; return 0; }
    fi

    for dir in "${dirs[@]}"; do
        _run_as "$install_path" rm -rf "$dir"
    done

    update_icon_cache "$install_path"
    echo "Uninstall complete."
}

# --- Interactive questionnaire ---
run_interactive() {
    local mode="" variants=()

    echo ""
    echo "  Adwaita Colors — Setup"
    echo "  ======================"
    echo ""

    # Step 1: action
    echo "  What would you like to do?"
    echo "    1) Install icon themes"
    echo "    2) Remove icon themes"
    local action_choice
    read -p "  (1/2): " action_choice
    case "$action_choice" in
        1) mode="install" ;;
        2) mode="uninstall" ;;
        *) echo "  Invalid choice."; exit 1 ;;
    esac

    # Step 2: variants
    echo ""
    echo "  Which color variants?"
    echo "    1) All 10 variants"
    echo "    2) Choose specific variants"
    local var_choice
    read -p "  (1/2): " var_choice

    if [[ "$var_choice" == "2" ]]; then
        echo ""
        echo "  Enter numbers separated by commas or spaces"
        for i in "${!ALL_VARIANTS[@]}"; do
            printf "    %2d) %s\n" $((i + 1)) "${ALL_VARIANTS[$i]}"
        done
        local selection
        read -p "  Selection: " selection
        for token in $(echo "$selection" | tr ',' ' '); do
            [[ "$token" =~ ^[0-9]+$ ]] || continue
            local idx=$((token - 1))
            [[ $idx -ge 0 && $idx -lt ${#ALL_VARIANTS[@]} ]] && variants+=("${ALL_VARIANTS[$idx]}")
        done
        [[ ${#variants[@]} -eq 0 ]] && variants=("${ALL_VARIANTS[@]}")
    else
        variants=("${ALL_VARIANTS[@]}")
    fi

    # Step 3-4: location + folders (install only)
    local with_folders=false
    local PREFIX=""
    if [[ "$mode" == "install" ]]; then
        echo ""
        echo "  Install location?"
        echo "    1) System-wide (/usr/share/icons) — may need sudo"
        echo "    2) Just for my user (~/.local/share/icons)"
        echo "    3) Custom path"
        local loc_choice
        read -p "  (1/2/3): " loc_choice
        case "$loc_choice" in
            1) PREFIX="" ;;
            2) PREFIX="$HOME/.local" ;;
            3) read -p "  Enter path (e.g. /usr, /app, ~/.local): " PREFIX ;;
            *) echo "  Invalid choice."; exit 1 ;;
        esac

        echo ""
        echo "  Include additional custom folder icons? (y/N)"
        echo "    These add branded folder icons (GitHub, GitLab, etc.)"
        local folder_choice
        read -p "  (y/N): " folder_choice
        [[ "$folder_choice" =~ ^[Yy]$ ]] && with_folders=true
    fi

    # Summary
    echo ""
    echo "  Summary"
    echo "  -------"
    echo "  Action:   ${mode}"
    echo "  Variants: ${variants[*]}"
    if [[ "$mode" == "install" ]]; then
        local path
        path=$(get_install_path "$PREFIX" "install")
        echo "  Location: ${path}"
        [[ "$with_folders" == true ]] && echo "  Custom folders: yes" || echo "  Custom folders: no"
    fi
    local confirm
    read -p "  Proceed? (Y/n): " confirm
    [[ ! "$confirm" =~ ^[Yy]$ ]] && { echo "  Cancelled."; exit 0; }

    case "$mode" in
        install)   do_install "$with_folders" "$PREFIX" "${variants[@]}" ;;
        uninstall) do_uninstall "$PREFIX" ;;
    esac
}

# --- Main ---

# No args → interactive
if [[ $# -eq 0 ]]; then
    run_interactive
    exit 0
fi

PREFIX=""
MODE=""
WITH_FOLDERS=false
VARIANTS=()

while [[ $# -gt 0 ]]; do
    case $1 in
        -i|--install)     MODE="install"; shift ;;
        -u|--uninstall)   MODE="uninstall"; shift ;;
        -f|--folders)     WITH_FOLDERS=true; shift ;;
        -P|--prefix)      PREFIX="$2"; shift 2 ;;
        -P=*|--prefix=*)  PREFIX="${1#*=}"; shift ;;
        -l|--list)        echo "Available variants: ${ALL_VARIANTS[*]}"; exit 0 ;;
        -h|--help)        show_help; exit 0 ;;
        -*)
            echo "Unknown option: $1"
            echo "Use -h or --help for usage information."
            exit 1 ;;
        *)
            VARIANTS+=("$1"); shift ;;
    esac
done

[ -z "$MODE" ] && { echo "Error: Specify -i (install) or -u (uninstall)."; echo "Use -h or --help for usage information."; exit 1; }
[ ${#VARIANTS[@]} -eq 0 ] && VARIANTS=("${ALL_VARIANTS[@]}")

for v in "${VARIANTS[@]}"; do
    [ "${IS_VALID_VARIANT[$v]}" ] || { echo "Error: Unknown variant '$v'"; echo "Available variants: ${ALL_VARIANTS[*]}"; exit 1; }
done

case "$MODE" in
    install)   do_install "$WITH_FOLDERS" "$PREFIX" "${VARIANTS[@]}" ;;
    uninstall) do_uninstall "$PREFIX" ;;
esac

exit 0
